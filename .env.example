# ═══════════════════════════════════════════════════════
# NEXUS — Environment Variables Reference
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All values shown here are safe defaults for local
# development using Docker emulators.
# ═══════════════════════════════════════════════════════

# ── Runtime Mode ──────────────────────────────────────
NEXUS_ENV=development
NODE_ENV=development
LOG_LEVEL=debug

# ── Google Cloud ──────────────────────────────────────
GOOGLE_CLOUD_PROJECT=nexus-platform
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GCP_REGION=us-central1

# ── Gemini API (required for narrative generation) ────
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Firebase / Firestore ──────────────────────────────
FIRESTORE_EMULATOR_HOST=localhost:9090
FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ── Pub/Sub ───────────────────────────────────────────
# NOTE: Port 8088, NOT 8085 (8085 is used by Remediation)
PUBSUB_EMULATOR_HOST=localhost:8088

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Gateway ───────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_SIGNING_SECRET=replace-with-a-secure-random-string
GATEWAY_CORS_ORIGIN=http://localhost:5173

# ── Interceptor ───────────────────────────────────────
INTERCEPTOR_PORT=8081
INTERCEPTOR_URL=http://localhost:8081

# ── Causal Engine ─────────────────────────────────────
CAUSAL_ENGINE_PORT=8082
CAUSAL_ENGINE_URL=http://localhost:8082

# ── Federated Aggregator ──────────────────────────────
FEDERATED_AGGREGATOR_PORT=8083

# ── Prediction Engine ─────────────────────────────────
PREDICTION_ENGINE_PORT=8084

# ── Remediation ───────────────────────────────────────
REMEDIATION_PORT=8085
REMEDIATION_URL=http://localhost:8085

# ── Vault ─────────────────────────────────────────────
VAULT_PORT=8086
VAULT_URL=http://localhost:8086

# ── Regulatory Intelligence ───────────────────────────
REGULATORY_INTELLIGENCE_PORT=8087

# ── Cloud KMS (production only) ───────────────────────
# In development, the vault falls back to HMAC signing
KMS_KEY_NAME=projects/nexus-platform/locations/us-central1/keyRings/nexus-audit-keys/cryptoKeys/audit-signer/cryptoKeyVersions/1

# ── BigQuery (production only) ────────────────────────
BIGQUERY_DATASET=nexus_analytics

# ── Cloud Storage (production only) ───────────────────
GCS_REPORTS_BUCKET=nexus-reports

# ── External Integrations (disabled for demo) ────────
SENDGRID_API_KEY=DEMO_DISABLED
SLACK_WEBHOOK_URL=DEMO_DISABLED
